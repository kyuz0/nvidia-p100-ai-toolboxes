FROM ghcr.io/sasha0552/vllm:v0.8.5.post1

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONNOUSERSITE=1

# Add required Fedora Toolbox compatibility labels
LABEL com.github.containers.toolbox="true" \
      usage="This image is meant to be used with the toolbox command" \
      summary="Nvidia P100 (sm_60) vLLM toolbox"

# Install toolbox dependencies, handle the machine-id so DBUS propagates, and free UID 1000
RUN apt-get update && apt-get install -y \
    sudo \
    libcap2-bin \
    libnss-myhostname \
    curl \
    libgomp1 \
    dialog \
    && apt-get clean \
    && rm -rf /var/lib/apt/lists/* \
    && rm -f /etc/machine-id && touch /etc/machine-id \
    && (userdel -r ubuntu || true) \
    && sed -i 's/^hosts:.*/& myhostname/' /etc/nsswitch.conf || true

# Copy the launcher, benchmark, and model catalogue
COPY models.json /opt/models.json
COPY start_vllm.py /usr/local/bin/start-vllm
COPY run_vllm_bench.py /usr/local/bin/run-vllm-bench
RUN chmod +x /usr/local/bin/start-vllm /usr/local/bin/run-vllm-bench

ENTRYPOINT []
CMD ["/bin/bash"]
